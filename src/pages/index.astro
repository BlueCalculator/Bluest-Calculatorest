---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
	<div class="welcomeBanner">
        <h1>Web design so fire, even my duck wants equity.</h1>
        <h2>Gamble your little heart out, earn loonies, and bribe your way into my portfolio</h2>
        <div class="buttonBox">
          <button type="button" class="button-good" onclick="scrollto('howToPlay')" >Start Playing</button>
          <button type="button" class="button-good">Skip to portfolio</button>  
        </div>
    </div>

    <div class="ascii-container">
      <pre class="ascii-art noUserSelect" id="ascii-duck"></pre>
      <pre class="ascii-art noUserSelect" id="ascii-calc"></pre>
    </div>
    <div class="logoWallWrapper">
      <div class="list logoWall">
        <h3>Companies I Never Applied To (But Email Me Anyway)</h3>
        <div class="logosSvg">
            <img src="/imgs/svgs/logoWall/A&W_Root_Beer-Logo.svg" alt="A&W" class="logoSvg">
            <img src="/imgs/svgs/logoWall/AccuWeather-Logo.svg" alt="Accu Weather" class="logoSvg">
            <img src="/imgs/svgs/logoWall/Blockbuster_LLC-Logo.svg" alt="Blockbuster" class="logoSvg">
            <img src="/imgs/svgs/logoWall/cloudflare.svg" alt="downflare" class="logoSvg">
            <img src="/imgs/svgs/logoWall/Docker_(software)-Logo.svg" alt="Docker" class="logoSvg">
            <img src="/imgs/svgs/logoWall/ethereum.svg" alt="Ethereum" class="logoSvg">
            <img src="/imgs/svgs/logoWall/Goodreads-Logo.svg" alt="Goodreads" class="logoSvg">
            <img src="/imgs/svgs/logoWall/google-domains.svg" alt="Google Domains" class="logoSvg">
            <img src="/imgs/svgs/logoWall/hcaptcha.svg" alt="hcaptcha" class="logoSvg">
            <img src="/imgs/svgs/logoWall/Intel-Logo.svg" alt="intel" class="logoSvg">
            <img src="/imgs/svgs/logoWall/micron.svg" alt="micron" class="logoSvg">
            <img src="/imgs/svgs/logoWall/microsoft-azure.svg" alt="azure" class="logoSvg">
            <img src="/imgs/svgs/logoWall/Nasdaq-Logo.svg" alt="nasdaq" class="logoSvg">
            <img src="/imgs/svgs/logoWall/python.svg" alt="python" class="logoSvg">
            <img src="/imgs/svgs/logoWall/redhat.svg" alt="redhat" class="logoSvg">
            <img src="/imgs/svgs/logoWall/spotify.svg" alt="spotify" class="logoSvg">
            <img src="/imgs/svgs/logoWall/Taco_Bell-Logo.svg" alt="tacoBell" class="logoSvg">
            <img src="/imgs/svgs/logoWall/Waffle_House-Logo.svg" alt="waffleHouse" class="logoSvg">
            <img src="/imgs/svgs/logoWall/YouTube-Logo.svg" alt="Youtube" class="logoSvg">
        </div>
      </div>
    </div>


    <div class="list howToPlay" id="howToPlay">
      <h3>How To Play</h3>
      <p>Earn loonies through minigames, then spend them to unlock exclusive portfolio content. No real money involved.
        <ul>
          <li>Pick a game from the hub below.</li>
          <li>Play and win loonies.</li>
          <li>Spend loonies on portfolio items.</li>
          <li>If ur boring, skip straight to summaries via "Skip to portfolio" button.</li>
          <li>If you need loonies go to the market.</li>
        </ul>
      </p>
    </div>

    <div class="list">

      <a class="gameItem" href="./games/rideTheBus">      
        <div class="rideTheBus">
          <p>RIDE THE BUS</p>
        </div>
      </a>
      <a class="gameItem" href="./games/slots">
        <div class="slots">
          <p>SLOTS</p>
        </div>
      </a>
 
    </div>
    <script is:inline>
    Promise.all([
      fetch('duck.txt').then(r => r.text()),
      fetch('calc.txt').then(r => r.text())
    ]).then(([duckText, calcText]) => {
      const duckPre = document.getElementById('ascii-duck');
      const calcPre = document.getElementById('ascii-calc');
      const container = duckPre.parentElement;
      
      duckPre.textContent = duckText;
      calcPre.textContent = calcText;
      
      const SIZE_MULTIPLIER = 0.8; 
      
      function resizeAscii() {
        duckPre.style.transform = 'none';
        calcPre.style.transform = 'none';
        duckPre.style.top = '0px';
        calcPre.style.top = '0px';
        
        const ww = window.innerWidth;
        const wh = window.innerHeight;
        
        const duckW = duckPre.offsetWidth;
        const duckH = duckPre.offsetHeight;
        const calcW = calcPre.offsetWidth;
        const calcH = calcPre.offsetHeight;
        
        if (duckW > 0 && calcW > 0) {
          const scaleW = (ww - 20) / (duckW + calcW + 40);
          
          const maxH = Math.max(duckH, calcH);
          const scaleH = (wh * 0.8) / maxH;
          
          const scale = Math.min(scaleW, scaleH) * SIZE_MULTIPLIER;
          
          duckPre.style.transform = `scale(${scale})`;
          calcPre.style.transform = `scale(${scale})`;
          
          const scaledMaxH = maxH * scale;
          
          duckPre.style.top = ((scaledMaxH - (duckH * scale)) / 2) + 'px';
          calcPre.style.top = ((scaledMaxH - (calcH * scale)) / 2) + 'px';
          
          container.style.height = Math.ceil(scaledMaxH) + 'px';
        }
      }
      
      window.addEventListener('resize', resizeAscii);
      setTimeout(resizeAscii, 50);
    }).catch(err => console.error('Error loading ASCII art:', err));


    function scrollto(id){
      const target = document.getElementById(id)
      target.scrollIntoView({ behavior: 'smooth' });
    }
    </script>
</Layout>

<style scoped>
    h1 {
      font-size: 4rem;
    }
    h2 {
      padding-bottom: 2rem;
      font-size: 2rem
    }
    button {
      padding: 1rem;
    }
    .welcomeBanner{
        padding-top: 100px;
        margin-bottom: 100px;
        text-align: center;
    }
    .logoSvg{
      width: 100px;
      max-height: 50px;
      filter: grayscale(100%) opacity(70%);      
      transition: filter 0.3s ease;
    }
    .logosSvg{
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
      justify-content: center;
      }
    .logoSvg:hover{
      filter: grayscale(0%) opacity(100%); 
    }
    .logoWall {
      display: flex;
      flex-direction: column;
    }
    .logoWallWrapper{
      position: relative;
      z-index: 1;
    }
    .logoWallWrapper::before {
      content: "";
      position: absolute;
      inset: auto 0 auto auto;
      width: 220px;
      height: 220px;
      top: 50%;
      right: -40px;
      transform: translateY(-50%);
      border-radius: 50%;
      background: blue;
      filter: blur(60px);
      z-index: -1;
    }
    .ascii-container {
      color: var(--duck-text-color);
      display: flex;
      flex-direction: row;
      justify-content: center;
      align-items: center;
      position: relative;
      width: 100vw;
      min-height: 20vh;
      margin-left: calc(-50vw + 50%);
      overflow: hidden;
      box-sizing: border-box;
    }

    pre.ascii-art {
      font-weight: bold;
      position: absolute;
      top: 0;
      margin: 0;
      padding: 0;
      font-family: 'JetBrains Mono', monospace, Consolas;
      white-space: pre;
      line-height: 1;
      will-change: transform;
    }

    #ascii-duck {
      left: 10px;
      transform-origin: left top;
    }

    #ascii-calc {
      right: 10px;
      transform-origin: right top;
    }

    .gameItem{
      background-color: var(--box-Background);
      border: 1px solid var(--solidLine);
      text-decoration: none;
      color: var(--text-color-all);
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      width: 200px;
      height: 200px;
      transition: .5s;
    }
    .gameItem:hover {
      transform: skew(1.5deg);
    }
    .howToPlay{
      flex-direction: column;
    }
</style>