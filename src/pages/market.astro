---
import Layout from '../layouts/Layout.astro';
import data from '../assets/lootBoxItems.json'
---

<Layout title="Market">
    <div class="outter">
        <div class="emailBuyer list displayColumn">
            <h2>Want My Email?</h2>
            <label for="BEmail">1000 Looniens:</label>
            <button class="button-good" id="BEmail" onclick="EmailBought()">Buy Email</button>
            <div id="BoughtEmail"></div>
        </div>
        <div class="needMoney list displayColumn">
            <h2>Do You Need Money?</h2>
            <button class="button-good" id="getMoneyBtn">Get Money</button>
        </div>
        <div id="plateWindowWindwo">
            <div class="plateWindow" id="plateWindow">
                <div id="exitButton">X</div>
                <h2>Click and drag to clean the plate.</h2>
                <div class="workingWindow" id="workingWindow">
                  <div class="stack" id="plateStack">
                    <img class="plates bottom" src="/imgs/plate.png" alt="">
                
                    <svg class="plates topMask" id="topMaskSvg" viewBox="0 0 100 100" preserveAspectRatio="none">
                      <defs>
                        <mask id="plateEraseMask" maskUnits="objectBoundingBox" maskContentUnits="userSpaceOnUse">
                          <rect x="0" y="0" width="100" height="100" fill="white"></rect>
                          <g id="eraseMarks"></g>
                        </mask>
                      </defs>
                  
                      <image
                        href="/imgs/dirtyPlate.png"
                        x="0"
                        y="0"
                        width="100"
                        height="100"
                        preserveAspectRatio="none"
                        mask="url(#plateEraseMask)"
                      />
                    </svg>
                  </div>
              
                  <img class="sponge" id="sponge" src="/imgs/sponge.png" alt="">
                </div>   
                <div class="buttonBoxRedeem">
                    <button type="button" class="button-good" id="loonieRedeemer">1 Loonie</button>         
                </div>
            </div>

        </div>
        <div class="buyAskin list displayColumn">
          <h2>Treat Yourself to Some Loot Boxes</h2>
          <div class="lootBoxes" >
            <div class="lootItem" id="woodBox">
              <img src="/imgs/shopImgs/woodBox.png" alt="Wood Box">
              <p>100 Loonies</p>
            </div>
            <div class="lootItem" id="silverBox">
              <img src="/imgs/shopImgs/silverBox.png" alt="Silver Box">
              <p>500 Loonies</p>
            </div>
            <div class="lootItem" id="dimondBox">
              <img src="/imgs/shopImgs/dimondBox.png" alt="Dimond Box">
              <p>1000 Looines</p>
            </div>
          </div>
        </div>
        <div id="lootBoxOpenWindow">
          <div id="scrollWheel"></div>
          <div id="barIndicatorLoot"></div>
          <button class="button-good" id="AddToBagBtn">Add To Bag</button>
        </div>
        <div class="list displayColumn" id="websiteBagIteams">
          <h2>Loot Bag</h2>
          <div id="lootBoxItemsDisplayInBag">

          </div>
        </div>

    </div>
</Layout>

<script is:inline define:vars={{ data }}>
    const $ = (id) => document.getElementById(id);
    let boughtEmail = $('BoughtEmail')
    const exitButton = $('exitButton')
    const plateWindow = $('plateWindowWindwo')
    const woodBox = $('woodBox')
    const silverBox = $('silverBox')
    const dimondBox = $('dimondBox')
    const lootBoxOpenWindow = $('lootBoxOpenWindow')
    const scrollWheel = $('scrollWheel')
    const getMoneyBtn = $('getMoneyBtn')
    const workingWindow =   $("workingWindow");
    const plateStack =  $("plateStack");
    const sponge =  $("sponge");
    const eraseMarks =  $("eraseMarks");
    const loonieRedeemer = $("loonieRedeemer")
    const AddToBagBtn = $("AddToBagBtn")
    const websiteBagIteams = $("websiteBagIteams")
    const lootBoxItemsDisplayInBag = $("lootBoxItemsDisplayInBag")

    plateWindow.style.display = "none"
    websiteBagIteams.style.display = "none"
    let lootboxWheelItems = [];
    let currentIteams = []

    const rarityOdds = {
      wood: {  1: 70, 2: 20, 3: 8, 4: 2, 5: 0 },
      silver: { 1: 20, 2: 25, 3: 30, 4: 20, 5: 5 },
      dimond: { 1: 5, 2: 15, 3: 25, 4: 35, 5: 20 }
    };

    function getCurrentBagHoldings() {
      return JSON.parse(localStorage.getItem('wonItems') || '[]');
    }

    function getCurrentActiveItems() {
      const raw = localStorage.getItem('activeItems');
    
      if (!raw || raw === 'undefined') {
        return {};
      }
    
      try {
        return JSON.parse(raw);
      } catch (err) {
        console.log('bad activeItems in storage:', raw);
        return {};
      }
    }

    getMoneyBtn.addEventListener("click", (e) => {
      plateWindow.style.display = 'block'
    })

    lootBoxItemsDisplayInBag.addEventListener('click', (e) => {
      const btn = e.target.closest('.bagActionBtn');
      if (!btn) return;

      const { action, itemname, sell, type } = btn.dataset

      if(action === 'sell'){

        const updatedSavedLootboxIteams = getCurrentBagHoldings().filter(
          id => String(id) !== String(itemname)
        );
            
        localStorage.setItem('wonItems', JSON.stringify(updatedSavedLootboxIteams));
        
        setPurseAmount(Number(getPurseAmount())+Number(sell))
        const itemDiv = btn.closest('.bagItem')
        itemDiv.remove()
      }
      else if (action === 'activate') {
        const activeItems = getCurrentActiveItems();
      
        if (activeItems[type] === itemname) {
          delete activeItems[type];
          btn.style.backgroundColor = '#007acc';
        } else {
          activeItems[type] = itemname;
          btn.style.backgroundColor = 'red';
        }

      
        localStorage.setItem('activeItems', JSON.stringify(activeItems));
      }
    });

    if(getCurrentBagHoldings().length != 0){
      updateWonItemsBag()
    }

    function updateWonItemsBag(){
      lootBoxItemsDisplayInBag.innerHTML = ''
      websiteBagIteams.style.display = "block"
      getCurrentBagHoldings().forEach((item) => {
        var foundItem = data.content.find(obj => obj.id === item);
        let htmlizedLootItmesFromStorage = `
            <div class="bagItem">
              <img src="/imgs/${foundItem.imgUrl ?? 'pixelCalc.png'}" alt="where da img @" class="bagImg">
              <h3>${foundItem.name}</h3>
              <p>${foundItem.description}</p>
              <button class="button-good bagActionBtn" data-action="sell" data-sell="${foundItem.rarity * 100}" data-itemname="${foundItem.id}">Sell for <span>${foundItem.rarity * 100}</span></button>
              <!-- <button class="button-good bagActionBtn" data-action="activate" data-type="${foundItem.type}" data-itemname="${foundItem.id}">Activate</button> -->
            </div>
        `
        lootBoxItemsDisplayInBag.innerHTML += htmlizedLootItmesFromStorage
      });
    }

    AddToBagBtn.addEventListener("click", () => {
      const wonItem = lootboxWheelItems[30];
      const savedLootboxIteams = JSON.parse(localStorage.getItem('wonItems') || '[]')

      savedLootboxIteams.push(wonItem.id);
      localStorage.setItem('wonItems', JSON.stringify(savedLootboxIteams)); 
    
      lootBoxOpenWindow.style.display = "none";
      lootboxWheelItems = [];
      AddToBagBtn.style.display = "none";
    
      updateWonItemsBag()
    });
      
    loonieRedeemer.addEventListener("click", (e) => {
      redeemLoonie(1)
    })

    exitButton.addEventListener("click", (e) => {
        plateWindow.style.display = "none"
    })

    dimondBox.addEventListener('click', (e) => {
        openBox("dimond", 1000)
    });
    silverBox.addEventListener('click', (e) => {
        openBox("silver", 500)
    });;
    woodBox.addEventListener('click', (e) => {
        openBox("wood", 100)
    });;

    function openBox(boxType, boxPrice) {
      if (getPurseAmount() >= boxPrice) {
        setPurseAmount(getPurseAmount()-boxPrice)
        for (let i = 0; i < 40; i++) {
          lootboxWheelItems.push(getRandomLootItem(rarityOdds[boxType], data.content));
        }
        lootBoxOpenWindow.style.display = 'block'
        populateSpinner(lootboxWheelItems)
        spinToItem(30)
        setTimeout(() => {
          AddToBagBtn.style.display = "block"
        }, 6000);
      }else {
        window.dispatchEvent(
          new CustomEvent('local-storage', {
            detail: {
              key: 'msg-bad',
              msg: "Your To Broke To Buy This.",
              bgc: "red",
              txtc: "White",
            },
          }),
        )
      }
    }

    window.addEventListener('resize', () => {
      if (currentWinningIndex === null) return;
    
      const stopX = getStopXForIndex(currentWinningIndex);
      scrollWheel.style.transition = 'none';
      scrollWheel.style.transform = `translateX(${stopX}px)`;
    });

    let currentWinningIndex = null;

    function getStopXForIndex(index) {
      const items = scrollWheel.querySelectorAll('.spinnerOutter');
      const winningItem = items[index];
      const lootWindow = document.getElementById('lootBoxOpenWindow');
    
      if (!winningItem || !lootWindow) return 0;
    
      const itemCenter = winningItem.offsetLeft + (winningItem.offsetWidth / 2);
      const windowCenter = lootWindow.clientWidth / 2;
    
      return windowCenter - itemCenter;
    }

    function spinToItem(winningIndex) {
      currentWinningIndex = winningIndex;
    
      scrollWheel.style.transition = 'none';
      scrollWheel.style.transform = 'translateX(0px)';
    
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          const stopX = getStopXForIndex(winningIndex);
        
          scrollWheel.style.transition = 'transform 6s cubic-bezier(.08,.8,.17,1)';
          scrollWheel.style.transform = `translateX(${stopX}px)`;
        });
      });
    }

    function populateSpinner(items) {
      LootBoxWheelItemsHtmlilized = items.map(item => `
        <div class="spinnerOutter">
          <div class="spinnerIteam li${item.rarity}">
            <div class="logoImgUrl" style="background-color:${item.backgroundColor};">
              <img src="/imgs/${item.imgUrl ?? 'pixelCalc.png'}" alt="">
            </div>
            <p>${item.name}</p>  
          </div>
        </div>`
      );
      scrollWheel.innerHTML = LootBoxWheelItemsHtmlilized.join('');
    }

    function getRandomLootItem(rarityOdds, lootItems) {
      const pool = [];
      for (const rarity in rarityOdds) {
        for (let i = 0; i < rarityOdds[rarity]; i++) pool.push(rarity);
      }
      const chosen = pool[Math.floor(Math.random() * pool.length)];
      const filtered = lootItems.filter(item => item.rarity === chosen);
      return filtered[Math.floor(Math.random() * filtered.length)];
    }
    
    function EmailBought(){
        let purseAmount = getPurseAmount()

        if(Number(purseAmount) >= 1000){
            boughtEmail.innerText = atob("Qmx1ZUNhbGN1bGF0b3JAZ21haWwuY29t")
            setPurseAmount(Number(purseAmount) - 1000)
        }else {
            window.dispatchEvent(
              new CustomEvent('local-storage', {
                detail: {
                  key: 'msg-bad',
                  msg: "Your To Broke To Buy This.",
                  bgc: "red",
                  txtc: "White",
                },
              }),
            )
        }
    }

    function getPurseAmount(){
        return localStorage.getItem('purseAmount')
    }

  
    function setPurseAmount(newAmount) {
      // update localStorage
      localStorage.setItem('purseAmount', newAmount)
                
      // fire custom event so listeners update
      window.dispatchEvent(
        new CustomEvent('local-storage', {
          detail: {
            key: 'purseAmount',
            value: newAmount,
          },
        }),
      )
    }



let isErasing = false;
let lastPoint = null;

const BRUSH_RADIUS = 5;
const STEP = 1.5;
const GRID_SIZE = 80;

const dirtGrid = Array.from({ length: GRID_SIZE }, () =>
  Array(GRID_SIZE).fill(1)
);

loonieRedeemer.style.display = 'none'

document.querySelectorAll('.no-drag').forEach(el => {
  el.addEventListener('dragstart', e => e.preventDefault());
});

function redeemLoonie(amount) {
    setPurseAmount(Number(getPurseAmount()) + Number(amount))
    loonieRedeemer.style.display = 'none'
    plateWindow.style.display = "none"
    resetCleaning()
}

function resetCleaning() {
  eraseMarks.replaceChildren();

  for (let row = 0; row < GRID_SIZE; row++) {
    dirtGrid[row].fill(1);
  }

  isErasing = false;
  lastPoint = null;
}

function moveSponge(localX, localY) {
  sponge.style.left = `${localX}px`;
  sponge.style.top = `${localY}px`;
}

function getRect() {
  return plateStack.getBoundingClientRect();
}

function getLocalPoint(e) {
  const rect = getRect();
  if (!rect.width || !rect.height) return null;

  return {
    x: e.clientX - rect.left,
    y: e.clientY - rect.top,
    width: rect.width,
    height: rect.height
  };
}

function toMaskPoint(localPoint) {
  return {
    x: Math.max(0, Math.min(100, (localPoint.x / localPoint.width) * 100)),
    y: Math.max(0, Math.min(100, (localPoint.y / localPoint.height) * 100))
  };
}

function getDirtyPercent() {
  let total = 0;

  for (let row = 0; row < GRID_SIZE; row++) {
    for (let col = 0; col < GRID_SIZE; col++) {
      total += dirtGrid[row][col];
    }
  }

  return (total / (GRID_SIZE * GRID_SIZE)) * 100;
}

function getCleanPercent() {
  return 100 - getDirtyPercent();
}

function affectGrid(point) {
  const brush = BRUSH_RADIUS;
  const cellSize = 100 / GRID_SIZE;

  for (let row = 0; row < GRID_SIZE; row++) {
    for (let col = 0; col < GRID_SIZE; col++) {
      const cx = (col + 0.5) * cellSize;
      const cy = (row + 0.5) * cellSize;
      const dx = cx - point.x;
      const dy = cy - point.y;
      const dist = Math.hypot(dx, dy);

      if (dist <= brush) {
        dirtGrid[row][col] = Math.max(0, dirtGrid[row][col] - 0.08);
      }
    }
  }
}

function stamp(point) {
  if (!Number.isFinite(point.x) || !Number.isFinite(point.y)) return;

  const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
  circle.setAttribute("cx", point.x);
  circle.setAttribute("cy", point.y);
  circle.setAttribute("r", BRUSH_RADIUS);

  circle.setAttribute("fill", "black");
  circle.setAttribute("fill-opacity", "0.08");

  eraseMarks.appendChild(circle);

  affectGrid(point)

  if(getCleanPercent() >= 88){
    loonieRedeemer.style.display = 'block'
  }

}

function eraseLine(point) {
  if (!lastPoint) {
    stamp(point);
    lastPoint = point;
    return;
  }

  const dx = point.x - lastPoint.x;
  const dy = point.y - lastPoint.y;
  const dist = Math.hypot(dx, dy);

  if (!dist) {
    stamp(point);
    lastPoint = point;
    return;
  }

  for (let i = 0; i <= dist; i += STEP) {
    const x = lastPoint.x + (dx * i) / dist;
    const y = lastPoint.y + (dy * i) / dist;
    stamp({ x, y });
  }

  lastPoint = point;
}

workingWindow.addEventListener("pointerdown", (e) => {
  const local = getLocalPoint(e);
  if (!local) return;

  isErasing = true;
  lastPoint = null;

  sponge.src = '/imgs/spongeCleaning.png'

  workingWindow.setPointerCapture?.(e.pointerId);
  document.body.classList.add("scrubbing");

  moveSponge(local.x, local.y);
  eraseLine(toMaskPoint(local));

  e.preventDefault();
});

workingWindow.addEventListener("pointermove", (e) => {
  const local = getLocalPoint(e);
  if (!local) return;

  moveSponge(local.x, local.y);

  if (!isErasing) return;

  eraseLine(toMaskPoint(local));
  e.preventDefault();
});

function stopErasing() {
    isErasing = false;
    lastPoint = null;
    sponge.src = '/imgs/sponge.png'
    document.body.classList.remove("scrubbing");
}

workingWindow.addEventListener("pointerup", stopErasing);
workingWindow.addEventListener("pointercancel", stopErasing);
workingWindow.addEventListener("lostpointercapture", stopErasing);
window.addEventListener("pointerup", stopErasing);
</script>



<style scoped>
